<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/Toolbar"
        android:elevation="8dp">

        <dev.octoshrimpy.quik.common.widget.QkTextView
            android:id="@+id/toolbarTitle"
            style="@style/ToolbarText"
            tools:text="Title" />

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:id="@+id/editorScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="4dp"
                android:text="@string/notification_customize_body_label" />

            <dev.octoshrimpy.quik.common.widget.QkTextView
                android:id="@+id/sampleBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"
                android:textIsSelectable="true"
                tools:text="Sample SMS body" />

            <Button
                android:id="@+id/selectSearchButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/notification_customize_use_selection_search" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:text="@string/notification_customize_search_label" />

            <dev.octoshrimpy.quik.common.widget.QkEditText
                android:id="@+id/searchText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/notification_customize_search_hint"
                android:inputType="textMultiLine|textCapSentences" />

            <Button
                android:id="@+id/selectExtractButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/notification_customize_use_selection_extract" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:text="@string/notification_customize_display_label" />

            <dev.octoshrimpy.quik.common.widget.QkEditText
                android:id="@+id/displayText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/notification_customize_display_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:focusable="false"
                android:cursorVisible="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:text="@string/notification_customize_prefix_label" />

            <dev.octoshrimpy.quik.common.widget.QkEditText
                android:id="@+id/prefixText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/notification_customize_prefix_hint"
                android:inputType="textCapSentences" />

            <CheckBox
                android:id="@+id/applyToAllSenders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/notification_customize_apply_to_all" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/notification_customize_save" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
